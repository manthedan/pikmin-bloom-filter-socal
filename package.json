{
  "name": "costa-mesa-pikmin-map",
  "version": "1.0.0",
  "description": "Unofficial Pikmin Bloom detector planner for LA/OC, built from OpenStreetMap data",
  "main": "index.js",
  "scripts": {
    "test": "node --test",
    "build:data": "node scripts/build-data.mjs",
    "serve": "python3 -m http.server 5173 -d public",
    "dev": "npm run serve",
    "build:cells": "node scripts/build-cells.mjs",
    "build": "npm run build:geofabrik",
    "build:geofabrik": "node scripts/build-geofabrik.mjs && npm run build:cells && npm run build:tiles",
    "build:tiles": "node scripts/build-cell-tiles.mjs",
    "netlify:build": "node scripts/validate-static-export.mjs",
    "export": "node scripts/validate-static-export.mjs"
  },
  "keywords": ["pikmin-bloom", "openstreetmap", "s2", "leaflet", "map"],
  "author": "manthedan",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/destination": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "nodes2ts": "^4.0.2"
  }
}
